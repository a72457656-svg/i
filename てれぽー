-- プレイヤー選択ボタン作成関数
local function RefreshPlayerList()
    -- 既存のリストをクリア
    for _, child in pairs(PlayerScroll:GetChildren()) do
        if child:IsA("TextButton") then
            child:Destroy()
        end
    end
    
    for _, player in pairs(game.Players:GetPlayers()) do
        if player ~= game.Players.LocalPlayer then  -- 自分以外
            local Btn = Instance.new("TextButton")
            Btn.Size = UDim2.new(1, -8, 0, 28)
            Btn.BackgroundColor3 = Color3.fromRGB(45, 45, 60)
            Btn.Text = player.Name
            Btn.TextColor3 = Color3.fromRGB(255, 255, 255)
            Btn.TextSize = 13
            Btn.Font = Enum.Font.GothamSemibold
            Btn.Parent = PlayerScroll
            
            local BtnCorner = Instance.new("UICorner")
            BtnCorner.CornerRadius = UDim.new(0, 6)
            BtnCorner.Parent = Btn
            
            Btn.MouseButton1Click:Connect(function()
                local localPlayer = game.Players.LocalPlayer
                if localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart") and 
                   player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                    
                    localPlayer.Character.HumanoidRootPart.CFrame = player.Character.HumanoidRootPart.CFrame + Vector3.new(0, 3, 0)
                    print(player.Name .. " にテレポートしました")
                    PlayerScroll.Visible = false
                    PlayerList.Text = "プレイヤーを選択 ▼"
                end
            end)
        end
    end
end

-- プレイヤー選択ボタンをクリックしたとき
PlayerList.MouseButton1Click:Connect(function()
    PlayerScroll.Visible = not PlayerScroll.Visible
    if PlayerScroll.Visible then
        RefreshPlayerList()
        PlayerList.Text = "プレイヤーを選択 ▲"
    else
        PlayerList.Text = "プレイヤーを選択 ▼"
    end
end)

